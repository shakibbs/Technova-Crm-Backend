# Copy this file to `.env` and fill in real values.
# `.env` is gitignored and must NEVER be committed.

# ---- Django core ----
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- Database ----
# Use `sqlite` for quick local dev, or `postgres` for production parity.
DATABASE_URL=sqlite:///db.sqlite3
# Example PostgreSQL connection string:
# DATABASE_URL=postgres://technova:password@localhost:5432/technova_crm

# ---- JWT / SimpleJWT ----
DJANGO_SIMPLEJWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
DJANGO_SIMPLEJWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Email (Gmail SMTP) ----
# Dev=console backend, Prod=Gmail SMTP with App Password.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=TechNova CRM <your-email@gmail.com>
